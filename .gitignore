# ==============================================================================
# Root .gitignore — Diploma Institute Management System
# ==============================================================================

# ─── Environment files — NEVER commit secrets ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
backend/.env.local
frontend/.env.local

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
*/node_modules/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
backend/logs/

# ─── Build artifacts ──────────────────────────────────────────────────────────
dist/
build/
.next/
out/

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.tsbuildinfo

# ─── Uploads ──────────────────────────────────────────────────────────────────
backend/uploads/
