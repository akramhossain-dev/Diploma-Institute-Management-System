# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dims_dev?retryWrites=true&w=majority

# ─── JWT (reserved for Phase 2) ───────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (reserved for Phase 3) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (reserved for Phase 3) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Super Admin Seed Credentials ─────────────────────
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=admin@gmail.com
SEED_ADMIN_NAME=Super Admin

