# ==============================================================================
# DIMS DOCKER COMPOSE CENTRAL ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env in the root directory before starting containers:
# cp .env.example .env
#
# Docker Compose will load variables from the root .env file automatically.
# ==============================================================================

# ─── Docker Compose Mapped Ports ──────────────────────────────────────────────
# Port mapped to the host for Next.js Frontend (accessible via browser)
FRONTEND_PORT=3000

# Port mapped to the host for Express Backend (accessible via browser/client)
BACKEND_PORT=5000

# Port mapped to the host for local MongoDB database
MONGO_PORT=27017

# ─── Backend Service Config ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB URI connection string
# For local MongoDB container (service name is 'mongodb'), use:
MONGO_URI=mongodb://mongodb:27017/diploma
# For Cloud MongoDB Atlas connection, replace with your connection string:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dims_dev?retryWrites=true&w=majority

# JWT Secrets (replace with secure random keys in production)
JWT_SECRET=dimsjwtsecretplaceholder1234567890abcdefghijklmnopqrstuvwx
JWT_REFRESH_SECRET=dimsrefreshsecretplaceholder1234567890abcdefghijklmnopqrstuv
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Allowed Origin (must match where frontend runs on the host browser)
CLIENT_URL=http://localhost:3000

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=dkexfgjlf
CLOUDINARY_API_KEY=532779196766516
CLOUDINARY_API_SECRET=eGQTnCDDKJFzVpqYr6t7Fsy8eWc

# SMTP Configuration (Gmail OAuth/App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=md.akramhossainjisan@gmail.com
SMTP_PASS=fzxv wwsh jnjk gpqm

# Super Admin Seed Credentials
# Required for DB seeding via node seed.js or docker compose run
SEED_ADMIN_EMAIL=admin@mrist.edu.bd
SEED_ADMIN_PASSWORD=Admin@MRIST2025
SEED_ADMIN_NAME=Super Admin

# ─── Frontend Service Config ──────────────────────────────────────────────────
# Public endpoint where the browser calls the backend API.
# In local Docker development, this must point to the backend's host-mapped port.
NEXT_PUBLIC_API_URL=http://localhost:5000/api
